  "$id": "https://gameforge.dev/api/schemas/sse-run-event-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "The `data:` payload object of one Server-Sent Event on GET /runs/{id}/events. The `data` field is a discriminated (`data_schema_version`) RunEventData union; `event_type` is the 14-value RunEventType. The SSE framing itself is `id:{seq}\\nevent:{type}\\ndata:{canonical_json}\\n\\n`.",
  "oneOf": [
    {
      "properties": {
        "attempt_no": {
          "type": "null"
        },
        "data": {
          "$ref": "#/$defs/RunQueuedDataV1"
        },
        "data_schema_version": {
          "const": "run-queued@1"
        },
        "event_type": {
          "const": "run.queued"
        }
      },
      "required": [
        "event_type",
        "data_schema_version",
        "data"
      ],
      "type": "object"
    },
    {
      "properties": {
        "attempt_no": {
          "type": "null"
        },
        "data": {
          "$ref": "#/$defs/CancelRequestedDataV1"
        },
        "data_schema_version": {
          "const": "cancel-requested@1"
        },
        "event_type": {
          "const": "run.cancel_requested"
        }
      },
      "required": [
        "event_type",
        "data_schema_version",
        "data"
      ],
      "type": "object"
    },
    {
      "properties": {
        "attempt_no": {
          "type": "null"
        },
        "data": {
          "$ref": "#/$defs/CommandAcceptedDataV1"
        },
        "data_schema_version": {
          "const": "command-accepted@1"
        },
        "event_type": {
          "const": "run.command_accepted"
        }
      },
      "required": [
        "event_type",
        "data_schema_version",
        "data"
      ],
      "type": "object"
    },
    {
      "properties": {
        "attempt_no": {
          "minimum": 1,
          "type": "integer"
        },
        "data": {
          "$ref": "#/$defs/AttemptLeasedDataV1"
        },
        "data_schema_version": {
          "const": "attempt-leased@1"
        },
        "event_type": {
          "const": "attempt.leased"
        }
      },
      "required": [
        "event_type",
        "data_schema_version",
        "data",
        "attempt_no"
      ],
      "type": "object"
    },
    {
      "properties": {
        "attempt_no": {
          "minimum": 1,
          "type": "integer"
        },
        "data": {
          "$ref": "#/$defs/AttemptStartedDataV1"
        },
        "data_schema_version": {
          "const": "attempt-started@1"
        },
        "event_type": {
          "const": "attempt.started"
        }
      },
      "required": [
        "event_type",
        "data_schema_version",
        "data",
        "attempt_no"
      ],
      "type": "object"
    },
    {
      "properties": {
        "attempt_no": {
          "minimum": 1,
          "type": "integer"
        },
        "data": {
          "$ref": "#/$defs/AttemptProgressDataV1"
        },
        "data_schema_version": {
          "const": "attempt-progress@1"
        },
        "event_type": {
          "const": "attempt.progress"
        }
      },
      "required": [
        "event_type",
        "data_schema_version",
        "data",
        "attempt_no"
      ],
      "type": "object"
    },
    {
      "properties": {
        "attempt_no": {
          "minimum": 1,
          "type": "integer"
        },
        "data": {
          "$ref": "#/$defs/LeaseExpiredDataV1"
        },
