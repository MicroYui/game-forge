      "title": "Attempt No"
    },
    "data": {
      "discriminator": {
        "mapping": {
          "attempt-leased@1": "#/$defs/AttemptLeasedDataV1",
          "attempt-progress@1": "#/$defs/AttemptProgressDataV1",
          "attempt-started@1": "#/$defs/AttemptStartedDataV1",
          "cancel-requested@1": "#/$defs/CancelRequestedDataV1",
          "command-accepted@1": "#/$defs/CommandAcceptedDataV1",
          "command-outcome@1": "#/$defs/CommandOutcomeDataV1",
          "lease-expired@1": "#/$defs/LeaseExpiredDataV1",
          "retry-scheduled@1": "#/$defs/RetryScheduledDataV1",
          "run-queued@1": "#/$defs/RunQueuedDataV1",
          "run-succeeded@1": "#/$defs/RunSucceededDataV1",
