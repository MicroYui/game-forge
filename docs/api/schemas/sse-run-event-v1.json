          "const": "lease-expired@1"
        },
        "event_type": {
          "const": "attempt.lease_expired"
        }
      },
      "required": [
        "event_type",
        "data_schema_version",
        "data",
        "attempt_no"
      ],
      "type": "object"
    },
    {
      "properties": {
        "attempt_no": {
          "minimum": 1,
          "type": "integer"
        },
        "data": {
          "$ref": "#/$defs/RetryScheduledDataV1"
