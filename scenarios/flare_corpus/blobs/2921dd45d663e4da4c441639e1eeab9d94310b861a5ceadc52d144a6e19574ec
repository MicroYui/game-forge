index 0000000000000000000000000000000000000000..6da6b4d2cabe444235a6256971eb5cd9e1783f1e
--- /dev/null
+++ b/mods/empyrean_campaign/cutscenes/ending.txt
@@ -0,0 +1,32 @@
+caption_margins=5,5
+caption_background=0,0,0,200
+music=music/unrest_theme.ogg
+
+[scene]
+image=images/menus/backgrounds/badlands.png,1
+caption=At long last, your journey across the surface and into the Underworld has come to an end.
+pause=8s
+caption=Upon entering The Pit, a glowing obelisk shined in the distance.
+pause=8s
+caption=Guarding the obelisk was Leziath, a formidable opponent, yet no match for Exiled who faced her.
+pause=8s
+caption=With Leziath's defeat, the path to the obelisk was clear.
+pause=8s
+image=images/cutscenes/obelisk.png,1
+caption=Not a moment after Leziath crumbles into a pile of bones, a bolt of lightning strikes the obelisk.
+pause=8s
+caption=Did Leziath cast a spell on the obelisk with her dying breath? Had Empyrean finally collapsed?
+pause=8s
+image=images/cutscenes/arrival.png,1
+caption=Maybe it's true what they say. No one returns from the surface. Most die or go missing. A few hide and survive, for a while.
+pause=8s
+caption=Even the Exiled.
+pause=8s
+
+INCLUDE cutscenes/credits.txt
+
+[vscroll]
+text=And a very special thanks to...
+text=You!
+
+separator=64
