+text_pos=605,70,400,left
+text_font=128,0,0,font_cursive
+text=1462/3/16
+requires_status=emp_il_notes_2
+
+[text]
+text_pos=605,120,400,left
+text_font=0,0,0,font_cursive
+text=The messenger to the Chamber called the mineral "Mastite". It was made clear that any we find must be brought to the surface. No questions. This stuff is obviously something special. They better make it worth our while.
+requires_status=emp_il_notes_2
+
+[text]
+text_pos=605,560,400,center
