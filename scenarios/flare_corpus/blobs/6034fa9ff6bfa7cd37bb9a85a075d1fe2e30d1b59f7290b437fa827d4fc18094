+[text]
+text_pos=605,70,400,left
+text_font=128,0,0,font_cursive
+text=1462/4/27
+requires_status=emp_il_notes_4
+
+[text]
+text_pos=605,120,400,left
+text_font=0,0,0,font_cursive
+text=The Chamber finally gave their response. They did send a few mages, but not nearly enough. There's a promise of a larger gold share when the excavation is complete. Somehow, I don't think Empyrean politics will allow such a thing to manifest.
+requires_status=emp_il_notes_4
+
+[text]
+text_pos=605,560,400,center
+text_font=128,0,0,font_regular
