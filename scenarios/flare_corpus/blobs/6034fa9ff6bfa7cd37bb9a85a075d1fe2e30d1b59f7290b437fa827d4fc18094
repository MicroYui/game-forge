+[text]
+text_pos=155,120,400,left
+text_font=0,0,0,font_cursive
+text=It's finally over! We reached a massive chamber inhabited by a giant antlion! The mages were able to hold it back while we grabbed everything that wasn't nailed down. Thought we were trapped when we had to barricade the gate. Thank the heavens that the portal brought us back here.
+requires_status=emp_il_notes_6
+
