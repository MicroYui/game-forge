+
+[text]
+text_pos=155,120,400,left
+text_font=0,0,0,font_cursive
+text=When we returned today, the layout of the first floor did not match our maps. Thankfully, an Empyrean mage made it back with us. I asked them to try sensing for human life on the lower levels. Zero results thus far, but I still have hope.
+requires_status=emp_il_notes_7
+
+[text]
+text_pos=155,560,400,center
+text_font=128,0,0,font_regular
+text=[Missing page]
+requires_not_status=emp_il_notes_7
+
