+[text]
+text_pos=605,120,400,left
+text_font=0,0,0,font_cursive
+text=They told me about the other expeditions, a tower in Black Oak City and a temple in the Stormrock region. Both just as fruitless.
+requires_status=emp_il_notes_1
+
+[text]
+text_pos=605,560,400,center
