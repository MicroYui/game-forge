+
+[text]
+text_pos=155,120,400,left
+text_font=0,0,0,font_cursive
+text=Today, we found a peculiar yellow-green mineral. Almost blinding to look at. Perhaps someone from the Empyrean Chamber knows what it is...
+requires_status=emp_il_notes_2
+
+[text]
+text_pos=155,560,400,center
