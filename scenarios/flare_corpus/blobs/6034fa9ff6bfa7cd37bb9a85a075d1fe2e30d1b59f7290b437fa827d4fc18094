+# [text]
+# text_pos=605,70,400,left
+# text_font=128,0,0,font_cursive
+# text=
+# requires_status=emp_il_notes_7
+
+[text]
+text_pos=605,120,400,left
+text_font=0,0,0,font_cursive
+text=The Chamber sees the situation differently. Orders came in for operations to be moved to other nearby sites. Krolan obeyed. Said he didn't want end up dead like "those guys". As if our guys are dead! When I find them, we're going to snag the rest of that Mastite for ourselves!
+requires_status=emp_il_notes_7
+
+[text]
+text_pos=605,560,400,center
+text_font=128,0,0,font_regular
+text=[Missing page]
+requires_not_status=emp_il_notes_7
