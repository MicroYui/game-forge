+[text]
+text_pos=155,120,400,left
+text_font=0,0,0,font_cursive
+text=I've calmed down enough to write a coherent letter to the Chamber requesting the resources we need. Now we just have to wait. In the meantime, we'll continue exploring as carefully as possible.
+requires_status=emp_il_notes_4
+
+[text]
+text_pos=155,560,400,center
