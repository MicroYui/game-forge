+# [text]
+# text_pos=605,70,400,left
+# text_font=128,0,0,font_cursive
+# text=
+# requires_status=emp_il_notes_3
+
+[text]
+text_pos=605,120,400,left
+text_font=0,0,0,font_cursive
+text=What does the Chamber's healer do? Gives him a measly potion! Why are we waiting until the damage is done? We need defensive mages! But somehow, that's out of the question for the Empyrean...
+requires_status=emp_il_notes_3
+
+[text]
+text_pos=605,560,400,center
+text_font=128,0,0,font_regular
